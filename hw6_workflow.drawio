        <!-- Arrow: Decision → P6 (YES) -->
        <mxCell id="17" value="YES ✓" style="edgeStyle=orthogonalEdgeStyle;fontColor=#27AE60;fontStyle=1;strokeColor=#27AE60;fontSize=11;" edge="1" source="8" target="9" parent="1">
