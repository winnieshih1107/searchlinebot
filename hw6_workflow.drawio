        <mxCell id="19" value="NO — Re-tune" style="edgeStyle=orthogonalEdgeStyle;fontColor=#C0392B;fontStyle=1;strokeColor=#C0392B;fontSize=11;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="8" target="6" parent="1">
